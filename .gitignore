__pycache__/
*.pyc
.venv/
venv/
node_modules/
.env
.DS_Store
# raw PDFs are large; commit deliberately, not by accident during dev
# (comment the next line out once you've decided to version the source docs)
# data/raw/**/*.pdf
.playwright-mcp/

# WPF budget briefs — copyrighted source PDFs (inputs for the Layer-2 context corpus).
wi-policy-forum/
# Derived WPF chunks contain ~the full brief text — keep them local too (rebuild via
# `python -m parsers.wpf_briefs`); Neon holds them, and explain() serves short
# attributed passages. Only the parser + counts-only QA report are committed.
data/canonical/context/

# Open Checkbook raw CSVs — 77MB across 5 years, and regenerable in ~7 min via
# `make fetch-checkbook` (each year verified against its published total, and
# sha256-pinned in data/raw/sources.yml). The canonical Parquet IS committed
# (6.2MB, lossless minus quasi_id) — see docs/OPEN-CHECKBOOK-API.md.
# Not a Git LFS candidate: LFS pointers are undiffable, and its bandwidth quota
# is consumed by every Vercel build fetch.
data/raw/city/checkbook/*.csv

# USAspending grant extracts — 13MB, regenerable via `make fetch-grants` and
# gated on two anchors per year. Canonical Parquet is committed instead.
data/raw/federal/grants/*.csv

.vercel
